# ══════════════════════════════════════════════════════════════
# options.config — 07_로봇실증기반보완 (★TT칩 20MHz + ★슈미트 히스테리시스). 칩 파라미터.
#   ★06 대비: FSR(XADC) 트리거에 슈미트 히스테리시스 추가 → 꾹 누르는 동안 1회만 발동·락 유지
#     (06 버그: 무필터 FSR 노이즈가 임계 들락날락 → 재발동·잠깐풀림·레이턴시 123µs 쓰레기값).
#   여기 값만 고치고  `make build && make rerun`. 명령줄 일회성:  make build SPI_DIV=1 (← 우선).
# ══════════════════════════════════════════════════════════════

SPI_DIV      = 2        # 칩→MCP SPI 속도. SCLK = 칩클럭/(2×SPI_DIV) = 20/(2×2)=5MHz @20MHz (MCP 최대 10MHz). 05(50MHz)는 4=6.25MHz
THRESH_V     = 0.650    # FSR 발동 임계전압 (V, 입력 0.55~1.0). 코드 = V×4096
FSR_RULE     = 0x005C   # FSR 반사 선택: 0x79=estop / 0x5A=덕포즈 / 0x5B=움츠림_덕포즈 / 0x5C=움츠림_현재 / 0=비활성
FLINCH_MS    = 200      # 움츠림 1회성 지속 (ms). 틱 = FLINCH_MS×CLK_MHZ×1000 (클럭상대, 자동 재계산)
CLK_MHZ      = 20       # ★TT칩 클럭 20MHz. 움츠림 틱 계산 + 반사지연 µs 환산용. (05=50)
RECOIL_RAD   = 0.30     # ★J5 움츠림 증가량(rad). 칩엔 ×57296 해서 0.001도로. 0.30rad≈17.2도
REFLEX_SPEED = 400      # ★반사(움츠림) 이동 속도율(1~100, 실로봇 move_spd_rate). estop 무관
PACE_US      = 400      # ★프레임 페이싱(µs). 20MHz는 SPI 느려 파이프라인↑ → 300→400 여유. PS usleep(PACE_US)
DEBOUNCE_MS  = 2        # ★FSR 디바운스(ms). 트리거 이만큼 지속돼야 발동 — 노이즈 자가발동 방지. 클럭상대→사이클(최대 ~3.27ms). 재합성X(make build)
HYST_SHIFT   = 2        # ★07 슈미트 히스테리시스 시프트. 해제임계 = THRESH_V×(1−1/2^HYST_SHIFT): 1=50%(빡빡)/2=25%(기본)/3=12.5%. ★재합성X(make build)
# ★슈미트: FSR 발동=THRESH_V, 해제=그 (1−1/2^HYST)배 밑에서만. 사이는 데드밴드(유지) → 꾹 누르면 1회만, 진짜 떼야 재무장(노이즈 재발동 방지).
#   THRESH_V 는 '안 누른 baseline' 보다 충분히 위로(해제점이 baseline 위여야 정상 해제). HYST_SHIFT 키우면(3,4) 해제점↑=더 헐겁(작은 노이즈에도 풀림), 줄이면(1) 빡빡.
