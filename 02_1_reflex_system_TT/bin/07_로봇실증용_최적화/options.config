# ══════════════════════════════════════════════════════════════
# options.config — 06_로봇실증용 (★TT칩 20MHz 조건 재현). 칩 파라미터.
#   ★05_통합과 기능 동일 + 클럭 20MHz 기준(FCLK·SPI·페이싱·움츠림틱 전부 20MHz로).
#   여기 값만 고치고  `make build && make rerun`. 명령줄 일회성:  make build SPI_DIV=1 (← 우선).
# ══════════════════════════════════════════════════════════════

SPI_DIV      = 2        # 칩→MCP SPI 속도. SCLK = 칩클럭/(2×SPI_DIV) = 20/(2×2)=5MHz @20MHz (MCP 최대 10MHz). 05(50MHz)는 4=6.25MHz
THRESH_V     = 0.35     # FSR 발동 임계전압 (V, 입력 0.55~1.0). 코드 = V×4096
FSR_RULE     = 0x005C   # FSR 반사 선택: 0x79=estop / 0x5A=덕포즈 / 0x5B=움츠림_덕포즈 / 0x5C=움츠림_현재 / 0=비활성
FLINCH_MS    = 100      # 움츠림 1회성 지속 (ms). 틱 = FLINCH_MS×CLK_MHZ×1000 (클럭상대, 자동 재계산)
CLK_MHZ      = 20       # ★TT칩 클럭 20MHz. 움츠림 틱 계산 + 반사지연 µs 환산용. (05=50)
RECOIL_RAD   = 0.30     # ★J5 움츠림 증가량(rad). 칩엔 ×57296 해서 0.001도로. 0.30rad≈17.2도
REFLEX_SPEED = 100      # ★반사(움츠림) 이동 속도율(1~100, 실로봇 move_spd_rate). estop 무관
PACE_US      = 400      # ★프레임 페이싱(µs). 20MHz는 SPI 느려 파이프라인↑ → 300→400 여유. PS usleep(PACE_US)
