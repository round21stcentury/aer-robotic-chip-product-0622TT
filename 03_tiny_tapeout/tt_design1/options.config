# ══════════════════════════════════════════════════════════════
# options.config — 칩 파라미터 (★make build / make rerun 이 이 값으로 빌드)
#   여기 값만 고치고  `make build && make rerun`  하면 됨 (명령줄 인자 불필요).
#   명령줄로 일회성 덮어쓰기도 가능:  make build SPI_DIV=6   (← 이 파일보다 우선)
#   줄을 지우면 Makefile 기본값 사용.
# ══════════════════════════════════════════════════════════════

SPI_DIV      = 4        # 칩→MCP SPI 속도 (클수록 느림). SCLK = 칩클럭 / (2×SPI_DIV)
THRESH_V     = 0.76     # FSR 발동 임계전압 (V, 입력 0.55~1.0). 코드 = V×4096
FSR_RULE     = 0x005A   # FSR 반사 선택: 0x79=estop / 0x5A=덕포즈 / 0x5B=움찔 / 0=비활성
FLINCH_MS    = 200      # 움찔(0x5B) 1회성 지속 (ms)
CLK_MHZ      = 50       # 칩 클럭 (MHz) — 움찔 틱 계산용. 칩 클럭 바뀌면 여기 조정
REFLEX_SPEED = 100      # 반사(덕포즈/움찔) 이동 속도율 (1~100, 실로봇 move_spd_rate). estop 무관
